<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.example.bloodline">
    <uses-permission android:name="android.permission.CALL_PHONE"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_local_hospital_black_24dp"
        android:label="@string/app_name"
        android:largeHeap="true"
        android:roundIcon="@drawable/ic_local_hospital_black_24dp"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:name=".MainActivity"
            android:label="@string/app_name"
            android:theme="@style/AppTheme.NoActionBar">

        </activity>
        <activity android:name=".Activities.RegisterationActivity"
            android:label="@string/app_name"
            android:theme="@style/AppTheme.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".Activities.LoginActivity"
            android:theme="@style/AppTheme.NoActionBar">

        </activity>
        <activity android:name=".Activities.UserHomeActivity"
            android:theme="@style/AppTheme">

        </activity>
        <activity android:name=".Activities.DonorListActivity"
            android:theme="@style/AppTheme">

        </activity>
        <activity android:name=".Activities.AdminDrawerActivity"
            android:theme="@style/AppTheme.NoActionBar">

        </activity>
        <activity android:name=".Activities.InfoActivity"
            android:theme="@style/AppTheme">

        </activity>

        <activity android:name=".Activities.Splash_Screen"
            android:theme="@style/AppTheme.NoActionBar">

        </activity>

    </application>


</manifest>