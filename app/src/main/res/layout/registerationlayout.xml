<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/regback"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:layout_anchorGravity="clip_vertical"
    app:layout_anchor="@id/profile_image"
    android:background="@drawable/image31">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#72FF0000"
        android:paddingLeft="20dp"
        android:paddingRight="20dp">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="55dp"
            android:paddingBottom="45dp"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_gravity="center"
            android:id="@+id/loginBanner"
            android:background="#fff">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/edtemail"
                    android:hint="Email_Id"
                    android:inputType="textCapWords"
                    android:padding="10dp"
                    android:textSize="16sp"/>

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:passwordToggleContentDescription="password"
                app:passwordToggleEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/edtpassword"
                    android:hint="Password"
                    android:padding="10dp"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:inputType="textPassword"/>

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/edtcontact"
                    android:hint="Contact No"
                    android:inputType="number"
                    android:padding="10dp"
                    android:textSize="16sp"/>

            </com.google.android.material.textfield.TextInputLayout>

            <CheckBox
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="I Want to be donor. "
                android:layout_marginTop="10dp"
                android:textSize="18dp"
                android:id="@+id/cbcheck"/>


        </androidx.appcompat.widget.LinearLayoutCompat>

        <de.hdodenhof.circleimageview.CircleImageView
            android:layout_width="100dp"
            android:id="@+id/profile_image"
            app:civ_border_width="3dp"
            android:layout_height="100dp"
            android:src="@drawable/loginlogo"
            android:elevation="5dp"
            app:layout_anchorGravity="center_horizontal"
            app:layout_anchor="@id/loginBanner"/>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/roundshape"
        android:text="Registeration"
        android:padding="10dp"
        android:id="@+id/btnregister"
        android:layout_marginTop="460dp"
        android:textStyle="bold"
        android:textColor="#fff"
        android:layout_gravity="center_horizontal"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/txtlogin"
        android:text="Already have an account ? Login here ."
        android:textSize="19dp"
        android:layout_marginLeft="30dp"
        android:textStyle="bold"
        android:layout_marginTop="540dp"
        android:textColor="#000"/>


</androidx.coordinatorlayout.widget.CoordinatorLayout>












