<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/logback"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:layout_anchorGravity="clip_vertical"
    app:layout_anchor="@id/profile_image"
    android:background="@drawable/image31">


    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#72FF0000"
        android:paddingLeft="20dp"
        android:paddingRight="20dp">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="55dp"
            android:paddingBottom="45dp"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_gravity="center"
            android:id="@+id/loginBanner"
            android:background="#fff">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/edtmbl"
                    android:hint="User Id/Contact No"
                    android:inputType="textCapWords"
                    android:padding="10dp"
                    android:textSize="16sp"/>

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:passwordToggleContentDescription="password"
                app:passwordToggleEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/edtupassword"
                    android:hint="Password"
                    android:padding="10dp"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:inputType="textPassword"/>

            </com.google.android.material.textfield.TextInputLayout>

        </androidx.appcompat.widget.LinearLayoutCompat>

        <de.hdodenhof.circleimageview.CircleImageView
            android:layout_width="100dp"
            android:id="@+id/profile_image"
            app:civ_border_width="3dp"
            android:layout_height="100dp"
            android:src="@drawable/loginlogo"
            android:elevation="5dp"
            app:layout_anchorGravity="center_horizontal"
            app:layout_anchor="@id/loginBanner"/>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/roundshape"
        android:text="LOGIN"
        android:padding="10dp"
        android:id="@+id/btnlogin"
        android:layout_marginTop="400dp"
        android:textStyle="bold"
        android:textColor="#fff"
        android:layout_gravity="center_horizontal"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>












