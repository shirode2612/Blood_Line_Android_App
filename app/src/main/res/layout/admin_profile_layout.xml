<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/regback"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:layout_anchorGravity="clip_vertical"
    app:layout_anchor="@id/profile_image">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#94C2088D"
        android:paddingLeft="20dp"
        android:paddingRight="20dp">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="55dp"
            android:paddingBottom="30dp"
            android:paddingLeft="10dp"
            android:layout_marginTop="80dp"
            android:paddingRight="10dp"
            android:layout_gravity="center"
            android:id="@+id/loginBanner"
            android:background="#fff">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textColorHint="#000"
                    android:id="@+id/txtname"
                    android:hint="Komal Shirode."
                    android:inputType="textCapWords"
                    android:padding="10dp"
                    android:textSize="16sp"/>

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/txtemail"
                    android:textColorHint="#000"
                    android:hint="komalshirode85@gmail.com"
                    android:padding="10dp"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:inputType="textPassword"/>

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/txtno"
                    android:textColorHint="#000"
                    android:hint="9096063885"
                    android:inputType="number"
                    android:textStyle="bold"
                    android:padding="10dp"
                    android:textSize="16sp"/>

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/txtaddress"
                    android:textColorHint="#000"
                    android:hint="Plot No 7, Ishwar Colony,Jalgaon."
                    android:inputType="number"
                    android:textStyle="bold"
                    android:padding="10dp"
                    android:textSize="16sp"/>

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/txtpincode"
                    android:hint="425001"
                    android:textColorHint="#000"
                    android:inputType="number"
                    android:textStyle="bold"
                    android:padding="10dp"
                    android:textSize="16sp"/>

            </com.google.android.material.textfield.TextInputLayout>




            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/txtbgroup"
                    android:hint="B+"
                    android:inputType="number"
                    android:textColorHint="#000"
                    android:textStyle="bold"
                    android:padding="10dp"
                    android:textSize="16sp"/>

            </com.google.android.material.textfield.TextInputLayout>


        </androidx.appcompat.widget.LinearLayoutCompat>

        <de.hdodenhof.circleimageview.CircleImageView
            android:layout_width="120dp"
            android:id="@+id/profile_new"
            app:civ_border_width="3dp"
            android:layout_height="120dp"
            android:src="@drawable/cutii"
            android:elevation="5dp"
            app:layout_anchorGravity="center_horizontal"
            app:layout_anchor="@id/loginBanner"/>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>











