<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="5dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/txtname"
            android:layout_width="match_parent"
            android:textColor="#fff"
            android:layout_marginTop="10dp"
            android:layout_marginLeft="15dp"
            android:layout_marginRight="15dp"
            android:layout_height="wrap_content"
            android:background="#451b2a"
            android:gravity="center"
            android:text="Name"
            android:textSize="20dp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/txtname"
            android:layout_margin="10dp"
            app:cardCornerRadius="35dp"
            app:cardElevation="8dp">

            <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

                <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/img"
                android:layout_width="90dp"
                android:layout_height="90dp"
                    android:layout_gravity="center"
                android:src="@drawable/ab_positive"/>

                <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#B3114F"
                android:layout_marginLeft="5dp"
                android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email_Id"
                        android:textColor="#fff"
                        android:textSize="20dp"
                        android:drawableLeft="@drawable/ic_email_black_24dp"
                        android:drawablePadding="15dp"
                        android:layout_marginTop="5dp"
                        android:id="@+id/txtemail"
                        android:layout_marginLeft="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Age"
                        android:textColor="#fff"
                        android:textSize="20dp"
                        android:drawableLeft="@drawable/ic_person_outline"
                        android:drawablePadding="15dp"
                        android:layout_marginTop="5dp"
                        android:id="@+id/txtdage"
                        android:layout_marginLeft="10dp"/>




                    <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="City"
                    android:textSize="20dp"
                    android:textColor="#fff"
                    android:layout_marginTop="10dp"
                    android:id="@+id/txtcity"
                    android:drawableLeft="@drawable/ic_location_city"
                    android:drawablePadding="15dp"
                    android:layout_marginLeft="10dp"/>

                    <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Address"
                    android:textSize="20dp"
                    android:textColor="#fff"
                    android:drawableLeft="@drawable/ic_home_black"
                    android:drawablePadding="15dp"
                    android:layout_marginTop="10dp"
                    android:id="@+id/txtaddress"
                    android:layout_marginLeft="10dp"/>

                    <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contact No"
                    android:textColor="#fff"
                    android:textSize="20dp"
                    android:drawableLeft="@drawable/ic_phone_black"
                    android:drawablePadding="15dp"
                    android:layout_marginTop="5dp"
                    android:id="@+id/txtmobno"
                    android:layout_marginLeft="10dp"/>

            </LinearLayout>
        </LinearLayout>
        </androidx.cardview.widget.CardView>

    </RelativeLayout>

</androidx.cardview.widget.CardView>

